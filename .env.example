# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=use_a_strong_random_password_here

# ─── JWT secrets (generate with: openssl rand -hex 64) ───────────────────────
JWT_SECRET=replace_with_64_byte_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex

# ─── AES-256-GCM encryption key (generate with: openssl rand -hex 32) ────────
ENCRYPTION_KEY=replace_with_32_byte_hex

# ─── Super admin initial credentials ─────────────────────────────────────────
# These are ONLY used on first seed. Change the password immediately after login.
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe_On_First_Login!

# ─── App config ───────────────────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com
NODE_ENV=production
