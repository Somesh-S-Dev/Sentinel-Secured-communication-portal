# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sentinel_user:CHANGE_ME@localhost:5432/sentinel_db"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_min_64_chars_random_string_here_use_openssl_rand_base64_64"
JWT_REPORTER_EXPIRY="7d"
JWT_ADMIN_EXPIRY="8h"
JWT_REFRESH_SECRET="CHANGE_ME_different_secret_for_refresh_tokens"
JWT_REFRESH_EXPIRY="30d"

# ─── Encryption (AES-256) ─────────────────────────────────────────────────────
ENCRYPTION_KEY="CHANGE_ME_32_byte_hex_key_use_openssl_rand_hex_32"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:4200"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads/encrypted"
MAX_FILE_SIZE_MB=25
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,application/pdf,video/mp4,audio/mpeg"

# ─── WebSocket ────────────────────────────────────────────────────────────────
WS_PORT=3001

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
